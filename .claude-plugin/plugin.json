{
  "name": "helmsman",
  "description": "Agentic SDLC workspace for Claude Code — guides developers from PRD to shipped code with a durable artifact dossier",
  "version": "0.1.1",
  "author": {
    "name": "helmsman-contributors"
  },
  "license": "MIT",
  "homepage": "https://github.com/helmsman-ai/helmsman-claude-plugin",
  "repository": "https://github.com/helmsman-ai/helmsman-claude-plugin",
  "keywords": [
    "sdlc",
    "workflow",
    "agents",
    "prd",
    "architecture",
    "tdd",
    "dossier"
  ],
  "agents": [
    "./agents/orchestrator.md",
    "./agents/prd-reviewer.md",
    "./agents/researcher.md",
    "./agents/architect.md",
    "./agents/implementer.md",
    "./agents/reviewer.md"
  ],
  "commands": [
    "./commands/helmsman-init.md",
    "./commands/start-project.md",
    "./commands/status.md",
    "./commands/advance.md",
    "./commands/approve.md",
    "./commands/comment.md",
    "./commands/override-gate.md",
    "./commands/projects.md",
    "./commands/jump-back.md",
    "./commands/propagate.md",
    "./commands/propagation-history.md",
    "./commands/snapshots.md",
    "./commands/dossier.md",
    "./commands/distill-memory.md"
  ],
  "skills": [
    "./skills/prd-review",
    "./skills/tech-design",
    "./skills/task-breakdown",
    "./skills/implementation",
    "./skills/code-review",
    "./skills/bugfix",
    "./skills/refactor",
    "./skills/spike",
    "./skills/experiment",
    "./skills/hotfix",
    "./skills/chore"
  ],
  "communitySkillsDir": "./community-skills",
  "skillOverrideDir": ".claude/skills",
  "modes": [
    "./modes/feature.yaml",
    "./modes/bugfix.yaml",
    "./modes/refactor.yaml",
    "./modes/spike.yaml",
    "./modes/experiment.yaml",
    "./modes/hotfix.yaml",
    "./modes/chore.yaml"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/inject-state.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-push-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-log.sh"
          }
        ]
      }
    ]
  }
}
